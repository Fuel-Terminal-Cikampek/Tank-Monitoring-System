    // ========================================
    // Function: Setup Infinite Scroll
    // ========================================
    window.setupInfiniteScroll = function() {
        // Remove previous scroll handler
        $('#historyPanel').off('scroll');

        // Add scroll handler
        $('#historyPanel').on('scroll', function() {
            if (!historyHasMore || historyLoading) {
                return;
            }

            var scrollTop = $(this).scrollTop();
            var scrollHeight = $(this)[0].scrollHeight;
            var clientHeight = $(this).height();

            // Check if scrolled to bottom (with 50px threshold)
            if (scrollTop + clientHeight >= scrollHeight - 50) {
                loadAlarmHistory(false); // append mode
            }
        });
    };

