                id: id,
                targetLevel: targetLevel,
                stagnantThresholdMinutes: threshold
            },
            success: function(response) {
                if (response.isValid) {
                    alert('Record updated successfully');

                    // Disable input fields
                    card.find('.edit-target-level').prop('disabled', true);
                    card.find('.edit-threshold').prop('disabled', true);

                    // Toggle buttons back
                    card.find('.btn-save').hide();
                    card.find('.btn-edit').show();
                    card.find('.btn-delete').show();
                } else {
                    alert('Error updating record: ' + response.message);
                }
            },
            error: function(xhr, status, error) {
                console.error('[saveHistoryCard] AJAX Error:', error);
                alert('Error updating record: ' + error);
            }
        });
    };

    // ========================================
    // Function: Delete History Card
    // ========================================
    window.deleteHistoryCard = function(id) {
        if (!confirm('Are you sure you want to delete this history record?')) {
            return;
        }

        $.ajax({
            url: '/TankMovements/DeleteHistory',
            type: 'POST',
            data: { id: id },
            success: function(response) {
                if (response.isValid) {
                    // Remove card from DOM
                    $('#history-card-' + id).fadeOut(300, function() {
                        $(this).remove();
                        // Update selected count
                        updateSelectedCount();
                    });
                } else {
                    alert('Error deleting record: ' + response.message);
                }
            },
            error: function(xhr, status, error) {
                console.error('[deleteHistoryCard] AJAX Error:', error);
                alert('Error deleting record: ' + error);
            }
        });
    };

    // ========================================
    // Function: Toggle Select All History
    // ========================================
    window.toggleSelectAllHistory = function() {
        var isChecked = $('#selectAllHistory').is(':checked');
        $('.history-checkbox').prop('checked', isChecked);
        updateSelectedCount();
    };

    // ========================================
    // Function: Update Selected Count
    // ========================================
    window.updateSelectedCount = function() {
        var selectedCount = $('.history-checkbox:checked').length;
        $('#selectedCount').text(selectedCount);
        $('#btnBulkDelete').prop('disabled', selectedCount === 0);
    };

    // ========================================
    // Function: Bulk Delete History
    // ========================================
    window.bulkDeleteHistory = function() {
        var selectedIds = [];
        $('.history-checkbox:checked').each(function() {
            selectedIds.push(parseInt($(this).attr('data-id')));
        });

        if (selectedIds.length === 0) {
            alert('Please select at least one record to delete');
            return;
        }

        if (!confirm('Are you sure you want to delete ' + selectedIds.length + ' selected record(s)?')) {
            return;
        }

        $.ajax({
            url: '/TankMovements/BulkDeleteHistory',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(selectedIds),
            success: function(response) {
                if (response.isValid) {
                    alert(response.message);

                    // Remove cards from DOM
                    selectedIds.forEach(function(id) {
                        $('#history-card-' + id).fadeOut(300, function() {
                            $(this).remove();
                        });
                    });

                    // Reset checkbox
                    $('#selectAllHistory').prop('checked', false);
                    updateSelectedCount();
                } else {
                    alert('Error deleting records: ' + response.message);
                }
            },
            error: function(xhr, status, error) {
                console.error('[bulkDeleteHistory] AJAX Error:', error);
                alert('Error deleting records: ' + error);
            }
        });
    };
</script>

