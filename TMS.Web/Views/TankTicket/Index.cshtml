    // ========================================
    // Function: Update Alarm Timers (Live Countdown)
    // ========================================
    window.updateAlarmTimers = function() {
        $('.card[data-tank]').each(function() {
            var card = $(this);
            var durationSeconds = parseInt(card.attr('data-duration-seconds'));

            // Increment duration by 1 second
            durationSeconds++;
            card.attr('data-duration-seconds', durationSeconds);

            // Format duration
            var days = Math.floor(durationSeconds / 86400);
            var hours = Math.floor((durationSeconds % 86400) / 3600);
            var minutes = Math.floor((durationSeconds % 3600) / 60);
            var seconds = durationSeconds % 60;

            var durationDisplay = '';
            if (days > 0) {
                durationDisplay = days + 'd ' + hours + 'h ' + minutes + 'm';
            } else if (hours > 0) {
                durationDisplay = hours + 'h ' + minutes + 'm ' + seconds + 's';
            } else {
                durationDisplay = minutes + 'm ' + seconds + 's';
            }

            // Update display
            card.find('.alarm-duration').text(durationDisplay);
        });

        // Run again after 1 second
        setTimeout(updateAlarmTimers, 1000);
    };

