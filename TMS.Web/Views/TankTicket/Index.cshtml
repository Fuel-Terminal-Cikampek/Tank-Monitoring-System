    // ========================================
    // Function: Load Alarm History (with lazy loading)
    // ========================================
    window.loadAlarmHistory = function(reset = true) {
        if (reset) {
            historyCurrentPage = 1;
            historyData = [];
            historyHasMore = true;
            $('#historyContainer').html('');
            $('#selectAllHistory').prop('checked', false);
        }

        if (!historyHasMore || historyLoading) {
            return;
        }

        historyLoading = true;
        $('#historyLoader').show();

        $.ajax({
            url: '/TankMovements/GetAlarmHistory',
            type: 'GET',
            data: { page: historyCurrentPage, pageSize: historyPageSize },
            success: function(response) {
                if (response.isValid) {
                    console.log('[loadAlarmHistory] Received ' + response.data.length + ' records (total: ' + response.totalCount + ')');

                    // Append data
                    historyData = historyData.concat(response.data);
                    historyHasMore = response.hasMore;
                    historyCurrentPage++;

                    // Render cards
                    renderHistoryCards(response.data, false); // append mode

                    // Show/hide UI elements
                    if (historyData.length > 0) {
                        $('#historyBulkActions').show();
                    }

                    if (!historyHasMore) {
                        $('#historyLoader').hide();
                        $('#historyEndMessage').show();
                    }
                } else {
                    $('#historyContainer').html('<div class="alert alert-danger">Error loading history: ' + response.message + '</div>');
                }

                historyLoading = false;
                $('#historyLoader').hide();
            },
            error: function(xhr, status, error) {
                console.error('[loadAlarmHistory] AJAX Error:', error);
                $('#historyContainer').html('<div class="alert alert-danger">Error loading history: ' + error + '</div>');
                historyLoading = false;
                $('#historyLoader').hide();
            }
        });
    };

