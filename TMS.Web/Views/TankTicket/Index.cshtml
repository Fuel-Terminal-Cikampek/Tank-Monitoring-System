@model TMS.Models.TankTicket
@using TMS.Web.Authorization

@{
    ViewData["Title"] = "Tank Ticket";
    Layout = "~/Views/Shared/_LayoutNew.cshtml";
}
@*Tank Ticket*@
<head>
    @section Scripts{
        <script type="text/javascript" asp-append-version="true">
            // ? Check if current user can modify data (admin only)
            var canModifyData = @Json.Serialize(User.CanModifyData());

            var oTable;
            var tableData = [];
            // ? SAFEGUARD: Use jQuery(document).ready(function($) {}) pattern
            jQuery(document).ready(function ($) {
                oTable = $('#tb-tankticket').DataTable({
                    "serverSide": true,
                    "scrollY": true,
                    "scrollX": true,
                    "autoWidth": false,
                    "scrollCollapse": true,
                    "paging": true,
                    "fixedColumns": true,
                    "processing": true,
                    "pageLength": 50,
                    "ajax": {
                        "url": "@Url.Action("LoadData")",
                        "type": "POST",
                        "datatype": "json",
                        "data": function (d) {
                            d.TankNameFilter = document.getElementById("tank-name").value;
                            d.OperationType = document.getElementById("operation-type").value;
                            d.OperationStatus = document.getElementById("operation-status").value;
                            d.TicketNumber = document.getElementById("ticket-number").value;

                            // ? FIX: Gunakan format yang SAMA dengan value input (dd MMMM yyyy)
                            var minVal = document.getElementById("min").value;
                            var maxVal = document.getElementById("max").value;

                            // ? Kalau kosong, default ke hari ini dengan format yang benar
                            d.minDateTime = minVal || moment().format('DD MMMM YYYY');
                            d.maxDateTime = maxVal || moment().format('DD MMMM YYYY');
                        },
                        "dataSrc": function(json) {
                            // ? DEBUGGING: Log received data
                            if (json.data && json.data.length > 0) {
                            }
                            return json.data;
                        }
                    },
                    "columns": [
                        {
                            "data": "id",  // ? GANTI dari "Id" ke "id" (lowercase)
                            "name": "Id",
                            "visible": false,
                            "searchable": false
                        },
                        {
                            "data": null,
                            "orderable": false,
                            "render": function (data, type, full, meta) {
                                if (!canModifyData) {
                                    return "<button type='button' class='btn btn-info' onclick='PrintData(" + full.id + ");'><i class='fas fa-print'></i></button>";  // ? full.id (lowercase)
                                }

                                var edit = "<button type='button' class='btn btn-warning' onclick='UpdateData(" + full.id + ");'><i class='fas fa-edit fa-lg'></i></button> ";  // ? full.id
                                var print = "<button type='button' class='btn btn-info' onclick='PrintData(" + full.id + ");'><i class='fas fa-print'></i></button> ";  // ? full.id
                                var post = full.saP_Response ? "" : "<button type='button' class='btn btn-success' onclick='PostData(" + full.id + ");'><i class='fas fa-upload'></i></button> ";  // ? full.id & saP_Response
                                var dlete = "<button type='button' class='btn btn-danger' onclick='DeleteData(" + full.id + ");'><i class='fas fa-trash-alt'></i></button>";  // ? full.id
                                return edit + print + post + dlete;
                            }
                        },
                        {
                            "data": "tank_Number",  // ? lowercase camelCase
                            "name": "Tank_Number",
                            "defaultContent": "-"
                        },
                        {
                            "data": "ticket_Number",  // ? lowercase camelCase
                            "name": "Ticket_Number",
                            "defaultContent": "-"
                        },
                        {
                            "data": "timestamp",  // ? lowercase
                            "name": "Timestamp",
                            "render": function (value) {
                                if (!value) return "-";
                                return moment(value).format('DD MMM YYYY HH:mm');
                            }
                        },
                        {
                            "data": "operation_Type",  // ? lowercase camelCase
                            "name": "Operation_Type",
                            "defaultContent": "-"
                        },
                        {
                            "data": "operation_Status",  // ? lowercase camelCase
                            "name": "Operation_Status",
                            "render": function (data) {
                                if (data == null) return "-";
                                if (data == 1) return '<span class="badge badge-success">OPEN</span>';
                                if (data == 2) return '<span class="badge badge-danger">CLOSE</span>';
                                return '<span class="badge badge-secondary">UNKNOWN</span>';
                            }
                        },
                        {
                            "data": "liquidLevel",  // ? lowercase camelCase
                            "name": "LiquidLevel",
                            "render": function (data) {
                                return data != null ? parseFloat(data).toFixed(0) : '0';
                            }
                        },
                        {
                            "data": "waterLevel",  // ? lowercase camelCase
                            "name": "WaterLevel",
                            "render": function (data) {
                                return data != null ? parseFloat(data).toFixed(0) : '0';
                            }
                        },
                        {
                            "data": "liquidTemperature",  // ? lowercase camelCase
                            "name": "LiquidTemperature",
                            "render": function (data) {
                                return data != null ? parseFloat(data).toFixed(2) : '0.00';
                            }
                        },
                        {
                            "data": "testTemperature",  // ? lowercase camelCase
                            "name": "TestTemperature",
                            "render": function (data) {
                                return data != null ? parseFloat(data).toFixed(2) : '0.00';
                            }
                        },
                        {
                            "data": "liquidDensity",  // ? lowercase camelCase
                            "name": "LiquidDensity",
                            "render": function (data) {
                                return data != null ? parseFloat(data).toFixed(3) : '0.000';
                            }
                        },
                        {
                            "data": "saP_Response",
                            "name": "SAP_Response",
                            "render": function (data, type, row) {
                                // ? Handle empty/null response
                                if (!data || data === "") {
                                    return '<span class="badge badge-warning">Not Synced</span>';
                                }

                                try {
                                    // ? Parse JSON string from SAP response
                                    var sapData = JSON.parse(data);

                                    // ? Check response type and show DescMsg
                                    if (sapData.Type === "S") {
                                        // Success - show DescMsg in green badge
                                        var message = sapData.DescMsg || "Success";
                                        return '<span class="badge badge-success">' + message + '</span>';
                                    } else if (sapData.Type === "E") {
                                        // Error - show DescMsg in red badge
                                        var message = sapData.DescMsg || "Error";
                                        return '<span class="badge badge-danger">' + message + '</span>';
                                    } else if (sapData.Type === "W") {
                                        // Warning - show DescMsg in yellow badge
                                        var message = sapData.DescMsg || "Warning";
                                        return '<span class="badge badge-warning">' + message + '</span>';
                                    } else {
                                        // Unknown type
                                        return '<span class="badge badge-secondary">Unknown Status</span>';
                                    }
                                } catch (e) {
                                    // ? Fallback if JSON parsing fails
                                    console.error("Failed to parse SAP response for row:", row.id, e);

                                    // Try to extract DescMsg from malformed JSON using regex
                                    var descMsgMatch = data.match(/"DescMsg":"([^"]+)"/);
                                    if (descMsgMatch && descMsgMatch[1]) {
                                        var message = descMsgMatch[1];
                                        // Check if it's success or error based on message content
                                        if (message.toLowerCase().includes("success") || message.toLowerCase().includes("posted")) {
                                            return '<span class="badge badge-success">' + message + '</span>';
                                        } else if (message.toLowerCase().includes("error") || message.toLowerCase().includes("failed")) {
                                            return '<span class="badge badge-danger">' + message + '</span>';
                                        } else {
                                            return '<span class="badge badge-warning">' + message + '</span>';
                                        }
                                    }

                                    // Ultimate fallback - simple string check
                                    if (data.includes("Success") || data.includes("succesfully") || data.includes("posted")) {
                                        return '<span class="badge badge-success">Synced Successfully</span>';
                                    } else if (data.includes("Error") || data.includes("Failed")) {
                                        return '<span class="badge badge-danger">Sync Failed</span>';
                                    } else {
                                        return '<span class="badge badge-secondary">Unknown</span>';
                                    }
                                }
                            }
                        }
                    ]
                });

                // Auto reload table
                var refreshIntervalSeconds = @ViewBag.RefreshIntervalSeconds ?? 10;
                var refreshIntervalMs = refreshIntervalSeconds * 1000;
                setInterval(reloadTable, refreshIntervalMs);
            });

            // ? FIX: PrintData function (alias untuk DownloadData)
            function PrintData(Id) {
                DownloadData(Id);
            }

            // ? FIX: PostData function
            function PostData(Id) {
                if (confirm('Upload ticket to SAP?')) {
                    $.ajax({
                        type: 'GET',
                        url: '@Url.Action("PostData")',
                        data: { id: Id },
                        success: function (res) {
                            oTable.ajax.reload(null, false);
                            if (res.Type === "S") {
                                alert('? Success: ' + res.DescMsg);
                            } else if (res.Type === "E") {
                                alert('? Error: ' + res.DescMsg);
                            } else if (res.Type === "W") {
                                alert('?? Warning: ' + res.DescMsg);
                            } else {
                                alert('?? Info: ' + JSON.stringify(res));
                            }
                        },
                        error: function (xhr) {
                            alert('? Error: ' + xhr.responseText);
                        }
                    });
                }
            }

            //Export Excel - Send filter parameters to get ALL data from database
            function ExportExcel() {
                // Get and format date values
                var dateFromValue = document.getElementById("min").value;
                var dateToValue = document.getElementById("max").value;

                // Format dates to ISO format if they have values
                var dateFrom = dateFromValue ? moment(dateFromValue, 'D MMMM yyyy').format('YYYY-MM-DD HH:mm:ss') : null;
                var dateTo = dateToValue ? moment(dateToValue, 'D MMMM yyyy').format('YYYY-MM-DD HH:mm:ss') : null;

                var opStatus = document.getElementById("operation-status").value;
                var filterData = {
                    TankName: document.getElementById("tank-name").value,
                    OperationType: document.getElementById("operation-type").value,
                    OperationStatus: opStatus ? parseInt(opStatus) : null,
                    TicketNumber: document.getElementById("ticket-number").value,
                    DateFrom: dateFrom,
                    DateTo: dateTo
                };

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("ExportToExcel", "TankTicket")',
                    data: filterData,  // Send as form data, NOT JSON.stringify
                    xhrFields: {
                        responseType: 'blob'
                    },
                    success: function (response, status, xhr) {
                        var filename = "";
                        var disposition = xhr.getResponseHeader('Content-Disposition');
                        if (disposition && disposition.indexOf('attachment') !== -1) {
                            var matches = /filename[^;=\n]*=((['"]).*?\2|[^;\n]*)/.exec(disposition);
                            if (matches != null && matches[1]) filename = matches[1].replace(/['"]/g, '');
                        }
                        var type = xhr.getResponseHeader('Content-Type');

                        var blob = new Blob([response], { type: type });

                        if (typeof window.navigator.msSaveBlob !== 'undefined') {
                            // IE workaround
                            window.navigator.msSaveBlob(blob, filename);
                        } else {
                            var URL = window.URL || window.webkitURL;
                            var downloadUrl = URL.createObjectURL(blob);

                            if (filename) {
                                // Use HTML5 a[download] attribute to specify filename
                                var a = document.createElement("a");
                                // Safari doesn't support this yet
                                if (typeof a.download === 'undefined') {
                                    window.location.href = downloadUrl;
                                } else {
                                    a.href = downloadUrl;
                                    a.download = filename;
                                    document.body.appendChild(a);
                                    a.click();
                                }
                            } else {
                                window.location.href = downloadUrl;
                            }

                            setTimeout(function () { URL.revokeObjectURL(downloadUrl); }, 100); // Cleanup
                        }
                    },
                    error: function (xhr, status, error) {
                    }
                });

            }

