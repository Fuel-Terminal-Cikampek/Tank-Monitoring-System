<script>
    // Global variable untuk alarm auto-refresh interval
    var alarmRefreshInterval = null;

    // ========================================
    // Function: Show Alarm Settings Modal
    // ========================================
    window.showAlarmSettingsModal = function() {

        try {
            // Reset form
            if ($('#alarmSettingsForm')[0]) {
                $('#alarmSettingsForm')[0].reset();
            }

            // Hide settings form group initially
            $('#settingsFormGroup').hide();
            $('#currentSettingsInfo').html('');

            // ? FIX: Manual modal show (jQuery conflict workaround)
            // Because jQuery is loaded twice in _Scripts.cshtml, Bootstrap modal plugin is removed
            var modalElement = $('#alarmSettingsModal');
            modalElement.addClass('show');
            modalElement.css('display', 'block');
            modalElement.attr('aria-modal', 'true');
            modalElement.attr('aria-hidden', 'false');

            // Add backdrop
            if ($('.modal-backdrop').length === 0) {
                $('body').append('<div class="modal-backdrop fade show"></div>');
            }

            // Add modal-open class to body
            $('body').addClass('modal-open');

            // ? Load active alarms by default (tab 1)
            switchToActiveAlarmsTab();
            loadActiveAlarms();

            // ? Start auto-refresh (every 5 seconds)
            if (alarmRefreshInterval) {
                clearInterval(alarmRefreshInterval);
            }
            alarmRefreshInterval = setInterval(function() {
                // Only refresh if Active Alarms tab is active
                if ($('#activeAlarmsTab').hasClass('active')) {
                    refreshActiveAlarms();
                }
            }, 5000); // 5 seconds
        } catch (error) {
            console.error('[showAlarmSettingsModal] Error opening modal:', error);
            alert('Error opening alarm settings modal. Please check console for details.');
        }
    };

    // ========================================
    // Function: Close Alarm Settings Modal
    // ========================================
    window.closeAlarmSettingsModal = function() {

        // ? Stop auto-refresh interval
        if (alarmRefreshInterval) {
            clearInterval(alarmRefreshInterval);
            alarmRefreshInterval = null;
        }

        // Hide modal
        var modalElement = $('#alarmSettingsModal');
        modalElement.removeClass('show');
        modalElement.css('display', 'none');
        modalElement.attr('aria-modal', 'false');
        modalElement.attr('aria-hidden', 'true');

        // Remove backdrop
        $('.modal-backdrop').remove();

        // Remove modal-open class from body
        $('body').removeClass('modal-open');
    };

    // ========================================
    // Function: Switch to Active Alarms Tab
    // ========================================
    window.switchToActiveAlarmsTab = function() {

        // Manual tab switching (Bootstrap tab plugin not available due to jQuery conflict)
        $('#activeAlarmsTab').addClass('active');
        $('#historyTab').removeClass('active');
        $('#settingsTab').removeClass('active');

        $('#activeAlarmsPanel').addClass('show active');
        $('#historyPanel').removeClass('show active');
        $('#settingsPanel').removeClass('show active');

        // Hide Save button in footer
        $('#btnSaveAlarmSettings').hide();
    };

    // ========================================
    // Function: Switch to History Tab
    // ========================================
    window.switchToHistoryTab = function() {

        // Manual tab switching
        $('#historyTab').addClass('active');
        $('#activeAlarmsTab').removeClass('active');
        $('#settingsTab').removeClass('active');

        $('#historyPanel').addClass('show active');
        $('#activeAlarmsPanel').removeClass('show active');
        $('#settingsPanel').removeClass('show active');

        // Hide Save button in footer
        $('#btnSaveAlarmSettings').hide();

        // Load history (first page)
        loadAlarmHistory();
    };

    // ========================================
    // Function: Switch to Settings Tab
    // ========================================
    window.switchToSettingsTab = function() {

        // Manual tab switching
        $('#settingsTab').addClass('active');
        $('#activeAlarmsTab').removeClass('active');
        $('#historyTab').removeClass('active');

        $('#settingsPanel').addClass('show active');
        $('#activeAlarmsPanel').removeClass('show active');
        $('#historyPanel').removeClass('show active');

        // Show Save button in footer
        $('#btnSaveAlarmSettings').show();

        // ? Load tanks with recent ROT tickets
        loadTanksWithRecentROT();
    };

    // ========================================
    // Function: Load Active Alarms
    // ========================================
    window.loadActiveAlarms = function() {

        $.ajax({
            url: '/TankMovements/GetActiveAlarmsWithDetails',
            type: 'GET',
            success: function(response) {
                if (response.isValid) {
                    renderAlarmCards(response.data, response.count);
                } else {
                    console.error('[loadActiveAlarms] Error:', response.message);
                    $('#activeAlarmsContainer').html('<div class="alert alert-danger">Error loading alarms: ' + response.message + '</div>');
                }
            },
            error: function(xhr, status, error) {
