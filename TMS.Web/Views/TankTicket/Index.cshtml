        @*Function Download Tank Ticket*@
        <script type="text/javascript" asp-append-version="true">

            function DownloadData(tankTicketId) {
                var toSend =
                {
                    id: tankTicketId
                };
                $.ajax({
                    url: '@Url.Action("PrintTankTicket", "TankTicket")',
                    data: toSend,
                    method: 'POST',
                    xhrFields: {
                        responseType: 'blob'
                    },
                    success: function (response, status, xhr) {
                        // Create a hidden link to download the file
                        var link = document.createElement('a');
                        link.href = window.URL.createObjectURL(new Blob([response]));
                        link.download = xhr.getResponseHeader('Content-Disposition').split('"')[1];
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                    },
                    error: function (xhr, status, error) {
                        // Handle the error
                    }
                });
            }

