            }



        </script>

        <!-- ? NEW: Tank Movement Threshold Modal Handler -->
        <script type="text/javascript">
            // ? Store tankTicketId for threshold modal
            var thresholdPendingTicketId = null;

            // ? Function untuk menampilkan modal Tank Movement threshold
            // ? FIXED: Use window scope so it can be called from AddNewTankTicket
            window.showTankMovementThresholdModal = function(tankNumber, tankTicketId) {

                // ? Store ticketId for use when saving
                thresholdPendingTicketId = tankTicketId || null;

                // Set tank number
                $('#thresholdTankNumber').val(tankNumber);
                
                // Get default values dari Tank (optional - bisa diisi via AJAX)
                $.ajax({
                    url: '@Url.Action("GetTankMovementDefaults", "TankMovements")',
                    type: 'GET',
                    data: { tankNumber: tankNumber },
                    success: function(data) {
                        if (data && data.isValid) {
                            $('#thresholdTargetLevel').val(data.targetLevel || 5000);
                            $('#thresholdAlarmMinutes').val(data.alarmMinutes || 5);
                            $('#thresholdStagnantMinutes').val(data.stagnantMinutes || 5);
                        }
                    },
                    error: function(err) {
                        // Use default values
                        $('#thresholdTargetLevel').val(5000);
                        $('#thresholdAlarmMinutes').val(5);
                        $('#thresholdStagnantMinutes').val(5);
                    }
                });
                
                // Show modal (Bootstrap 4)
                $('#tankMovementThresholdModal').modal('show');
            }
            
            // ? Handler untuk tombol Skip
            $(document).on('click', '#btnSkipThreshold', function() {
                $('#tankMovementThresholdModal').modal('hide');
                
                // Reload table
                if (typeof oTable !== 'undefined' && oTable && oTable.ajax) {
                    oTable.ajax.reload(null, false);
                }
            });
            
            // ? Handler untuk tombol Simpan
            $(document).on('click', '#btnSaveThreshold', function() {
                var tankNumber = $('#thresholdTankNumber').val();
                var targetLevel = parseInt($('#thresholdTargetLevel').val()) || 5000;
                var alarmMinutes = parseInt($('#thresholdAlarmMinutes').val()) || 5;
                var stagnantMinutes = parseInt($('#thresholdStagnantMinutes').val()) || 5;
                
                // Disable button during save
                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Menyimpan...');
                
                $.ajax({
                    url: '@Url.Action("SetTankMovementThreshold", "TankMovements")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        TankNumber: tankNumber,
                        TargetLevel: targetLevel,
                        AlarmMinutes: alarmMinutes,
                        StagnantThresholdMinutes: stagnantMinutes,
                        TankTicketId: thresholdPendingTicketId  // ? Include tankTicketId from ROT Open
                    }),
                    success: function(response) {
                        btn.prop('disabled', false).html('<i class="fas fa-save mr-1"></i> Simpan & Aktifkan');

                        if (response.isValid) {
                            // ? Clear pending ticketId after save
                            thresholdPendingTicketId = null;
                            $('#tankMovementThresholdModal').modal('hide');
                            alert('? Tank Movement monitoring berhasil diaktivasi!\n\nAlarm akan berbunyi jika tidak ada flowrate selama ' + stagnantMinutes + ' menit.');
                        } else {
                            alert('? Error: ' + (response.message || 'Gagal menyimpan threshold'));
                        }
                        
                        // Reload table
                        if (typeof oTable !== 'undefined' && oTable && oTable.ajax) {
                            oTable.ajax.reload(null, false);
                        }
                    },
                    error: function(xhr, status, error) {
                        btn.prop('disabled', false).html('<i class="fas fa-save mr-1"></i> Simpan & Aktifkan');
                        console.error("[ThresholdModal] Error:", error);
                        alert('? Error: ' + error);
                    }
                });
            });
        </script>

        @* ? DISABLED: TICKET NO-FLOWRATE ALARM POLLING - temporarily disabled *@
        @*
        <script type="text/javascript">
            // ? Tank Ticket No Flowrate Alarm Polling (In-Memory, Auto-Clear)
            var ticketAlarmInterval;
            var alarmPollingMs = @ViewBag.TicketNoFlowrateAlarmPollingMs ?? 3000; // Default 3 seconds
            var ticketAlarmAudio = new Audio('/audio/alarm-low.mp3'); // Reuse existing alarm sound
            ticketAlarmAudio.loop = true;
            var isTicketAlarmPlaying = false;

            function checkTicketNoFlowrateAlarm() {
                $.ajax({
                    url: '@Url.Action("TriggerTicketNoFlowrateAlarm", "TankTicket")',
                    type: 'GET',
                    contentType: 'application/json; charset=utf-8',
                    success: function (response) {
                        if (response.isValid && response.data.length > 0) {

                            // Play alarm sound if not already playing
                            if (!isTicketAlarmPlaying) {
                                ticketAlarmAudio.play().catch(function(error) {
                                });
                                isTicketAlarmPlaying = true;
                            }

                            // Log alarm messages to console
                            response.data.forEach(function(alarm) {
                                var flowrate = alarm.currentFlowrate || alarm.CurrentFlowrate || 0;
                                var elapsed = alarm.elapsedMinutes || alarm.ElapsedMinutes || 0;
                                console.log(`  - Elapsed: ${elapsed} min, Flowrate: ${flowrate.toFixed(2)} KL/h`);
                            });

                            // TODO: Show visual notification (optional - bisa pakai toast/modal)
                            // showAlarmNotification(response.data);
                        } else {
                            // ? AUTO-CLEAR: Stop alarm sound if no alarms (ada flowrate)
                            if (isTicketAlarmPlaying) {
                                ticketAlarmAudio.pause();
                                ticketAlarmAudio.currentTime = 0;
                                isTicketAlarmPlaying = false;
                                console.log("[TicketAlarm] Alarm auto-cleared (flowrate detected)");
                            }
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("[TicketAlarm] Check error:", error);
                    }
                });
            }

            // ? ACK single ticket alarm
            function ackTicketAlarm(ticketId) {
                $.ajax({
                    url: '@Url.Action("AckTicketNoFlowrateAlarm", "TankTicket")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(ticketId),
                    success: function (response) {
                        if (response.isValid) {
                            // Stop alarm sound temporarily (will restart after threshold if no flowrate)
                            if (isTicketAlarmPlaying) {
                                ticketAlarmAudio.pause();
                                ticketAlarmAudio.currentTime = 0;
                                isTicketAlarmPlaying = false;
                            }
                            // Optional: Show success message
                            // alert("Alarm acknowledged. Countdown restarted.");
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("[TicketAlarm] ACK error:", error);
                    }
                });
            }

            // ? ACK all ticket alarms
            function ackAllTicketAlarms() {
                $.ajax({
                    url: '@Url.Action("AckAllTicketNoFlowrateAlarms", "TankTicket")',
                    type: 'POST',
                    contentType: 'application/json',
                    success: function (response) {
                        if (response.isValid) {
                            // Stop alarm sound
                            if (isTicketAlarmPlaying) {
                                ticketAlarmAudio.pause();
                                ticketAlarmAudio.currentTime = 0;
                                isTicketAlarmPlaying = false;
                            }
                            // Optional: Show success message
                            // alert(response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("[TicketAlarm] ACK ALL error:", error);
                    }
                });
            }

            // ? Start polling when page loads
            // ? SAFEGUARD: Use jQuery(document).ready(function($) {}) pattern
            jQuery(document).ready(function($) {
                console.log(`[TicketAlarm] Starting alarm polling (interval: ${alarmPollingMs}ms)`);
                checkTicketNoFlowrateAlarm(); // Initial check
                ticketAlarmInterval = setInterval(checkTicketNoFlowrateAlarm, alarmPollingMs);
            });

            // ? Stop polling when leaving page (cleanup)
            $(window).on('beforeunload', function() {
                clearInterval(ticketAlarmInterval);
                if (isTicketAlarmPlaying) {
                    ticketAlarmAudio.pause();
                }
            });
        </script>
        *@
    }
    

