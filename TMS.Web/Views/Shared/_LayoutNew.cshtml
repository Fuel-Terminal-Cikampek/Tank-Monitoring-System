            </li>

            <!-- Divider -->
            <hr class="sidebar-divider d-none d-md-block">

            <!-- Sidebar Toggler (Sidebar) -->
            <div class="text-center d-none d-md-inline">
                <button class="rounded-circle border-0" id="sidebarToggle"></button>
            </div>

            <!-- Sidebar Logo Citia -->
            <div class="sidebar-card d-none d-lg-flex bg-transparent">
                <a href="https://citia-engineering.com/">
                    <img src="~/assets/img/citia_logo_putih.png" alt="Citia Engineering" width="90" height="90" class="py-1" />
                </a>
            </div>
        </ul>
        <!-- End Sidebar -->

        <div class="content-wrapper" style="width: 100%;">
            <!-- Topbar -->
            <nav class="navbar navbar-expand navbar-light bg-white topbar mb-4 static-top shadow">

                <!-- Sidebar Toggle (Topbar) -->
                <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                    <i class="fa fa-bars"></i>
                </button>

                <!-- Topbar Title -->
                <p class="navbar-item" style="
                    font-size: clamp(1rem, 1.5vw, 1.4rem);
                    font-weight: 800;
                    color: #000;
                    line-height: 1.3;
                    margin: auto 0;
                    padding: 0.5rem 0;
                ">
                    Tank Management System - Fuel Terminal Cikampek
                </p>

                <!-- Audio Elements -->
                <audio id="alarmAudioLow" src="~/audio/alarm-low.mp3"></audio>
                <audio id="alarmAudioHigh" src="~/audio/alarm-high.mp3"></audio>

                <!-- Topbar Navbar -->
                <ul class="navbar-nav ml-auto">

                    <!-- Nav Item - Alerts -->
                    <li class="nav-item dropdown no-arrow mx-1 d-flex align-items-center">
                        
                        <!-- ✅ ACK BUTTON - Mematikan SEMUA alarm (GLOBAL) -->
                        <button class="btn btn-danger mr-3" 
                                type="button" 
                                onclick="ackAllAlarms()"
                                title="Matikan semua alarm yang berbunyi"
                                style="width:130px; font-weight:800; font-size:1.2rem; padding: 8px 16px;">
                            <i class="fas fa-volume-mute mr-1"></i> ACK
                        </button>

                        <!-- ✅ BELL ICON - Alarm Log (aktif + history) -->
                        <a class="nav-link dropdown-toggle" href="#" id="alertsDropdown" 
                           data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" 
                           style="font-size:2.25rem;" title="Lihat riwayat alarm">
                            <i class="fas fa-bell fa-fw"></i>
                            <!-- Counter Badge (hanya alarm AKTIF) -->
                            <span id="count-alarm" class="badge badge-danger badge-counter" style="display: none;"></span>
                        </a>
                        
                        <!-- Dropdown - Alarm Log -->
                        <div class="dropdown-list dropdown-menu dropdown-menu-right shadow animated--grow-in"
                             aria-labelledby="alertsDropdown" 
                             style="min-width: 450px; max-height: 500px; overflow-y: auto;">
                            <h5 class="dropdown-header bg-info text-white">
                                <i class="fas fa-list-alt mr-2"></i>
                                Log Alarm
                            </h5>
                            <div id="alarms-container" style="font-size: 0.95rem;">
                                <!-- Alarm items will be inserted here by JavaScript -->
                                <a class="dropdown-item d-flex align-items-center" href="#">
                                    <div>
                                        <span class="font-weight-bold text-muted">
                                            <i class="fas fa-spinner fa-spin mr-2"></i>Memuat...
                                        </span>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </li>

                    <!-- Nav Item - User Information -->
                    <li class="nav-item dropdown no-arrow">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                           data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <span class="mr-2 d-none d-lg-inline text-gray-600 small">@UserManager.GetUserName(User)</span>
                            <img class="img-profile rounded-circle" src="~/assets/img/undraw_profile.svg">
                        </a>
                        <!-- Dropdown - User Information -->
                        <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in"
                             aria-labelledby="userDropdown">
                            <a class="dropdown-item" href="user/profile.html">
                                <i class="fas fa-user fa-sm fa-fw mr-2 text-gray-400"></i>
                                Profile
                            </a>
                            <a class="dropdown-item" href="#">
                                <i class="fas fa-list fa-sm fa-fw mr-2 text-gray-400"></i>
                                Activity Log
                            </a>
                            <div class="dropdown-divider"></div>
                            <form id="form_logout" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                <a class="dropdown-item" href="javascript:{}" onclick="document.getElementById('form_logout').submit();">
                                    <i class="fas fa-sign-out-alt fa-sm fa-fw mr-2 text-gray-400"></i>
                                    Logout
                                </a>
                            </form>
                        </div>
                    </li>

                </ul>

            </nav>
            <!-- End of Topbar -->
            @RenderBody()
        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="form-modal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" style="font-size: 1.25rem; color: black;">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Edit Data</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                </div>
                <div class="modal-footer">
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="custom-modal" tabindex="-1" role="dialog" aria-labelledby="mySmallModalLabel" aria-hidden="true" style="margin-top: -20px;">
        <div class="modal-dialog">
            <div class="modal-content" style="box-shadow: 0 4px 8px rgba(0, 0, 0, 0.6);">
                <div class="modal-header">
                    <h5 class="modal-title" style="color:black; font-size: 2rem; font-weight: 600;">Alert</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body" style="font-size: 1.5rem; font-weight: 600">
                    <p>Modal body text goes here.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" id="bt-alert" onclick="CloseModal()" data-dismiss="modal" aria-label="Close" class="btn btn-primary" style="width:40%;">OK</button>
                </div>
            </div>
        </div>
    </div>

    <partial name="_Scripts" />

    <script>
        function CloseModal() {
            $('#custom-modal').modal('hide');
        }
        
        // ========================================
        // ✅ SIDEBAR STATE PERSISTENCE
        // Simpan posisi sidebar (open/hide) di localStorage
        // ========================================
        jQuery(document).ready(function($) {
            
            // ✅ 1. Load saved sidebar state saat halaman load
            var savedSidebarState = localStorage.getItem('sidebarToggled');
            var sidebar = $('#accordionSidebar');
            var body = $('body');
            
            if (savedSidebarState === 'true') {
                // Sidebar was toggled (collapsed) - apply immediately without animation
                sidebar.addClass('toggled');
                body.addClass('sidebar-toggled');
            } else if (savedSidebarState === 'false') {
                // Sidebar was open - ensure it's open
                sidebar.removeClass('toggled');
                body.removeClass('sidebar-toggled');
            }
            // If null (first visit), use default state (open)
            
            // ✅ 2. Save sidebar state when toggle button clicked
            $('#sidebarToggle, #sidebarToggleTop').on('click', function() {
                // Wait for toggle animation to complete
                setTimeout(function() {
                    var isToggled = sidebar.hasClass('toggled');
                    localStorage.setItem('sidebarToggled', isToggled);
                    console.log('[Sidebar] State saved:', isToggled ? 'collapsed' : 'expanded');
                }, 100);
            });
            
            // ✅ 3. Handle sidebar submenu hover saat toggled
            handleSidebarSubmenu();
            
            $('#sidebarToggle, #sidebarToggleTop').on('click', function() {
                setTimeout(handleSidebarSubmenu, 300);
            });
            
            // MutationObserver untuk detect class changes
            var observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'class') {
                        handleSidebarSubmenu();
                    }
                });
            });
            
            var sidebarElement = document.getElementById('accordionSidebar');
            if (sidebarElement) {
                observer.observe(sidebarElement, { attributes: true });
            }
        });
        
        // ✅ FIX: Sidebar toggled - submenu hover behavior
        function handleSidebarSubmenu() {
            var $ = jQuery;
            var sidebar = $('#accordionSidebar');
            
            if (sidebar.hasClass('toggled')) {
                // Sidebar collapsed - use hover untuk show submenu
                $('.sidebar .nav-item').off('mouseenter.submenu mouseleave.submenu');
                
                $('.sidebar .nav-item').on('mouseenter.submenu', function() {
                    if (sidebar.hasClass('toggled')) {
                        $(this).find('.collapse').addClass('show');
                    }
                });
                
                $('.sidebar .nav-item').on('mouseleave.submenu', function() {
                    if (sidebar.hasClass('toggled')) {
                        $(this).find('.collapse').removeClass('show');
                    }
                });
            } else {
                // Sidebar expanded - remove hover handlers, use click (default Bootstrap behavior)
                $('.sidebar .nav-item').off('mouseenter.submenu mouseleave.submenu');
            }
        }
    </script>

    @if (IsSectionDefined("AddToHead"))
    {
        @RenderSection("AddToHead", required: false)
    }
    @RenderSection("Scripts", required: false)
</body>
</html>
