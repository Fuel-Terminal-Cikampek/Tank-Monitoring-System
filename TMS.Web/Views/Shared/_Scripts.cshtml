<script type="text/javascript">
    // ✅ SAFEGUARD: Pastikan $ selalu merujuk ke jQuery
    // Browser DevTools kadang override $ dengan document.querySelector
    (function() {
        // Store jQuery reference
        var jQ = window.jQuery;

        // Force $ to be jQuery
        window.$ = jQ;

        // Log confirmation

        // Re-assign $ after short delay (in case something overwrites it)
        setTimeout(function() {
            if (window.$ !== window.jQuery) {
                window.$ = window.jQuery;
            }
        }, 100);
    })();
</script>
