                </th>
                <th>
                    @Html.DisplayNameFor(model => model.IsAutoPI)
                </th> *@
                @* <th>
                    @Html.DisplayNameFor(model => model.IsManualLevel)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.ManualLevel)
                </th> *@
                <th>
                    @Html.DisplayNameFor(model => model.IsManualWaterLevel)
                </th>
                @*<th>
                    @Html.DisplayNameFor(model => model.ManualWaterLevel)
                </th>*@
                <th>
                    @Html.DisplayNameFor(model => model.IsManualDensity)
                </th>
                @*<th>
                    @Html.DisplayNameFor(model => model.ManualLabDensity)
                </th>*@
                <th>
                    @Html.DisplayNameFor(model => model.IsManualTemp)
                </th>
                @*<th>
                    @Html.DisplayNameFor(model => model.ManualTemp)
                </th>*@
                <th>
                    @Html.DisplayNameFor(model => model.IsManualTestTemp)
                </th>
                @*<th>
                    @Html.DisplayNameFor(model => model.ManualTestTemp)
                </th>*@
