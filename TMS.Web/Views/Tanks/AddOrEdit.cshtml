@model TMS.Models.Tank

@{
    ViewData["Title"] = "AddOrEdit";
    Layout = null;
}
<div class="row">
    <div class="col-md-12">
        <form asp-action="AddOrEdit" asp-route-id="@Model.Tank_Name" onsubmit="return jQueryAjaxPost(this);" autocomplete="off">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group row">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="Tank_Name" class="control-label"></label>
                    @if (string.IsNullOrEmpty(Model.Tank_Name))
                    {
                        <!-- NEW mode: Tank_Name can be entered -->
                        <input asp-for="Tank_Name" class="form-control" />
                    }
                    else
                    {
                        <!-- EDIT mode: Tank_Name is readonly (it's the primary key) -->
                        <input asp-for="Tank_Name" class="form-control" readonly style="background-color: #e9ecef;" />
                        <input type="hidden" asp-for="Tank_Name" />
                    }
                    <span asp-validation-for="Tank_Name" class="text-danger"></span>
                </div>
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="Product_ID" class="control-label"></label>
                    <select asp-for="Product_ID" class="form-control" asp-items=@(new SelectList(ViewBag.ProductId,"Product_Code","Product_Name"))></select>
                    <span asp-validation-for="Product_ID" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="TankVolume" class="control-label"></label>
                    <input asp-for="TankVolume" class="form-control" />
                    <span asp-validation-for="TankVolume" class="text-danger"></span>
                </div>

                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="Tank_Height" class="control-label"></label>
                    <input asp-for="Tank_Height" class="form-control" />
                    <span asp-validation-for="Tank_Height" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="Tank_Diameter" class="control-label"></label>
                    <input asp-for="Tank_Diameter" class="form-control" />
                    <span asp-validation-for="Tank_Diameter" class="text-danger"></span>
                </div>

                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="VolumeSafeCapacity" class="control-label"></label>
                    <input asp-for="VolumeSafeCapacity" class="form-control" />
                    <span asp-validation-for="VolumeSafeCapacity" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group row">

                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="Height_Deadstock" class="control-label"></label>
                    <input asp-for="Height_Deadstock" class="form-control" />
                    <span asp-validation-for="Height_Deadstock" class="text-danger"></span>
                </div>

                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="Blank" class="control-label"></label>
                    <input asp-for="Blank" class="form-control" />
                    <span asp-validation-for="Blank" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="Tape" class="control-label"></label>
                    <input asp-for="Tape" class="form-control" />
                    <span asp-validation-for="Tape" class="text-danger"></span>
                </div>
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="Bob" class="control-label"></label>
                    <input asp-for="Bob" class="form-control" />
                    <span asp-validation-for="Bob" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="IsUsed" class="control-label"></label>
                    <select asp-for="IsUsed" class="custom-select">
                        <option value="True">True</option>
                        <option value="False">False</option>
                    </select>
                    <span asp-validation-for="IsUsed" class="text-danger"></span>
                </div>
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="IsAutoPI" class="control-label"></label>
                    <select asp-for="IsAutoPI" class="custom-select">
                        <option value="True">True</option>
                        <option value="False">False</option>
                    </select>
                    <span asp-validation-for="IsAutoPI" class="text-danger"></span>
                </div>
            </div>

            @* <div class="form-group row">
            <div class="col-sm-6 mb-3 mb-sm-0">
                <label asp-for="IsManualLevel" class="control-label"></label>
                <select asp-for="IsManualLevel" class="custom-select">
                    <option value="True">True</option>
                    <option value="False">False</option>
                </select>
                <span asp-validation-for="IsManualLevel" class="text-danger"></span>
            </div>

            <div class="col-sm-6 mb-3 mb-sm-0">
                <label asp-for="ManualLevel" class="control-label">Manual Level</label>
                <input asp-for="ManualLevel" class="form-control" />
                <span asp-validation-for="ManualLevel" class="text-danger"></span>
            </div>
        </div> *@

            <div class="form-group row">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="IsManualTemp" class="control-label"></label>
                    <select asp-for="IsManualTemp" class="custom-select">
                        <option value="True">True</option>
                        <option value="False">False</option>
                    </select>
                    <span asp-validation-for="IsManualTemp" class="text-danger"></span>
                </div>
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="ManualTemp" class="control-label"></label>
                    <input asp-for="ManualTemp" class="form-control" />
                    <span asp-validation-for="ManualTemp" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="IsManualTestTemp" class="control-label"></label>
                    <select asp-for="IsManualTestTemp" class="custom-select">
                        <option value="True">True</option>
                        <option value="False">False</option>
                    </select>
                    <span asp-validation-for="IsManualTestTemp" class="text-danger"></span>
                </div>
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="ManualTestTemp" class="control-label"></label>
                    <input asp-for="ManualTestTemp" class="form-control" />
                    <span asp-validation-for="ManualTestTemp" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-6 mb-3 mb-sm-0">
                    <label asp-for="IsManualDensity" class="control-label"></label>
                    <select asp-for="IsManualDensity" class="custom-select">
                        <option value="True">True</option>
                        <option value="False">False</option>
                    </select>
                    <span asp-validation-for="IsManualDensity" class="text-danger"></span>
                </div>
                <div class="col-sm-6 mb-3 mb-sm-0">
