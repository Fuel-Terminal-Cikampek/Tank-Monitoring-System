                </div>
                <div class="col-sm-2 mb-3 mb-sm-0">
                    <label asp-for="LevelLL" class="control-label"></label>
                    <input asp-for="LevelLL" class="form-control" />
                    <span asp-validation-for="LevelLL" class="text-danger"></span>
                </div>
                <div class="col-sm-4 mb-3 mb-sm-0">
                    <label asp-for="UseAlarmL" class="control-label"></label>
                    <select asp-for="UseAlarmL" class="custom-select">
                        <option value="True">True</option>
                        <option value="False">False</option>
                    </select>
                    <span asp-validation-for="UseAlarmL" class="text-danger"></span>
                </div>
                <div class="col-sm-2 mb-3 mb-sm-0">
                    <label asp-for="LevelL" class="control-label"></label>
                    <input asp-for="LevelL" class="form-control" />
                    <span asp-validation-for="LevelL" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-4 mb-3 mb-sm-0">
                    <label asp-for="UseAlarmH" class="control-label"></label>
                    <select asp-for="UseAlarmH" class="custom-select">
                        <option value="True">True</option>
                        <option value="False">False</option>
                    </select>
                    <span asp-validation-for="UseAlarmH" class="text-danger"></span>
                </div>
                <div class="col-sm-2 mb-3 mb-sm-0">
                    <label asp-for="LevelH" class="control-label"></label>
                    <input asp-for="LevelH" class="form-control" />
                    <span asp-validation-for="LevelH" class="text-danger"></span>
                </div>
                <div class="col-sm-4 mb-3 mb-sm-0">
                    <label asp-for="UseAlarmHH" class="control-label"></label>
                    <select asp-for="UseAlarmHH" class="custom-select">
                        <option value="True">True</option>
                        <option value="False">False</option>
                    </select>
                    <span asp-validation-for="UseAlarmHH" class="text-danger"></span>
                </div>
                <div class="col-sm-2 mb-2 mb-sm-0">
                    <label asp-for="LevelHH" class="control-label"></label>
                    <input asp-for="LevelHH" class="form-control" />
                    <span asp-validation-for="LevelHH" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-sm-4 mb-3 mb-sm-0">
                    <label asp-for="UseAlarmTempL" class="control-label"></label>
                    <select asp-for="UseAlarmTempL" class="custom-select">
                        <option value="True">True</option>
                        <option value="False">False</option>
                    </select>
                    <span asp-validation-for="UseAlarmTempL" class="text-danger"></span>
                </div>
                <div class="col-sm-2 mb-3 mb-sm-0">
                    <label asp-for="TempL" class="control-label"></label>
                    <input asp-for="TempL" class="form-control" />
                    <span asp-validation-for="TempL" class="text-danger"></span>
                </div>
                <div class="col-sm-4 mb-3 mb-sm-0">
                    <label asp-for="UseAlarmTempH" class="control-label"></label>
                    <select asp-for="UseAlarmTempH" class="custom-select">
                        <option value="True">True</option>
                        <option value="False">False</option>
                    </select>
                    <span asp-validation-for="UseAlarmTempH" class="text-danger"></span>
                </div>
                <div class="col-sm-2 mb-3 mb-sm-0">
                    <label asp-for="TempH" class="control-label"></label>
                    <input asp-for="TempH" class="form-control" />
                    <span asp-validation-for="TempH" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group col text-center mt-lg-5">
                <button type="submit" class="btn btn-success" style="width:50%">Save changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
