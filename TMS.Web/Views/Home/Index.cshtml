        @@media (min-width: 1920px) and (max-width: 2559px) {
            .tank-value-icon {
                width: 34px;  /* ? INCREASED */
                height: 34px;
                font-size: 1.4rem !important;
            }
        }

        @@media (min-width: 2560px) {
            .tank-value-icon {
                width: 38px;  /* ? INCREASED */
                height: 38px;
                font-size: 1.6rem !important;
            }
        }

        /* ========================================
           ✅ ALARM INDICATOR - POSISI KIRI ATAS CARD
           (Seperti di gambar - lingkaran merah)
           ======================================== */
        .alarm-indicator-container {
            position: absolute;
            top: 8px;
            left: 8px;
            z-index: 15;
            display: flex;
            flex-direction: column;
            gap: 4px;
            max-width: 120px;
            pointer-events: auto;
        }

        .alarm-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 3px;
            padding: 3px 8px;
            border-radius: 50%;
