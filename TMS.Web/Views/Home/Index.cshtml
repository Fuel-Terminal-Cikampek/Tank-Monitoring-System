<!-- ========================================
     MODAL: Tank Alarm Management (Dashboard)
     Same as TankTicket page - with 3 tabs
     ======================================== -->
<div class="modal fade" id="dashboardAlarmSettingsModal" tabindex="-1" role="dialog" aria-labelledby="dashboardAlarmSettingsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header bg-warning text-white">
                <h5 class="modal-title" id="dashboardAlarmSettingsModalLabel">
                    <i class="fas fa-bell"></i> Tank Alarm Management
                </h5>
                <button type="button" class="close text-white" onclick="closeDashboardAlarmModal();" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <!-- Tab Navigation -->
            <ul class="nav nav-tabs" id="dashboardAlarmTabs" role="tablist" style="margin-left: 15px; margin-right: 15px; margin-top: 10px;">
                <li class="nav-item">
                    <a class="nav-link active" id="dbActiveAlarmsTab" data-toggle="tab" href="#dbActiveAlarmsPanel" role="tab" onclick="switchToDashboardActiveAlarmsTab()">
                        <i class="fas fa-exclamation-triangle"></i> Active Alarms <span id="dbAlarmBadge" class="badge badge-danger">0</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="dbHistoryTab" data-toggle="tab" href="#dbHistoryPanel" role="tab" onclick="switchToDashboardHistoryTab()">
                        <i class="fas fa-history"></i> History
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="dbSettingsTab" data-toggle="tab" href="#dbSettingsPanel" role="tab" onclick="switchToDashboardSettingsTab()">
                        <i class="fas fa-cog"></i> Settings
                    </a>
                </li>
            </ul>

            <div class="modal-body">
                <!-- Tab Content -->
                <div class="tab-content" id="dashboardAlarmTabContent">

                    <!-- Panel 1: Active Alarms -->
                    <div class="tab-pane fade show active" id="dbActiveAlarmsPanel" role="tabpanel">
                        <div id="dbActiveAlarmsContainer">
                            <div class="text-center py-4">
                                <div class="spinner-border text-warning" role="status">
                                    <span class="sr-only">Loading...</span>
                                </div>
                                <p class="mt-2">Loading active alarms...</p>
                            </div>
                        </div>

                        <div class="mt-3" id="dbActiveAlarmsActions" style="display: none;">
                            <button type="button" class="btn btn-success btn-sm" onclick="dbBulkAckAllAlarms()">
                                <i class="fas fa-check-double"></i> ACK All Alarms
                            </button>
                            <button type="button" class="btn btn-info btn-sm" onclick="dbRefreshActiveAlarms()">
                                <i class="fas fa-sync"></i> Refresh
                            </button>
                        </div>
                    </div>

                    <!-- Panel 2: History -->
                    <div class="tab-pane fade" id="dbHistoryPanel" role="tabpanel">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> View and manage stopped Tank Movement records. Use lazy loading (10 records per page).
                        </div>

                        <div id="dbHistoryContainer">
                            <div class="text-center py-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="sr-only">Loading...</span>
                                </div>
                                <p class="mt-2">Loading history...</p>
                            </div>
                        </div>

                        <!-- Bulk Delete Actions -->
                        <div class="mt-3" id="dbHistoryBulkActions" style="display: none;">
                            <div class="form-check d-inline-block mr-3">
                                <input class="form-check-input" type="checkbox" id="dbSelectAllHistory" onchange="dbToggleSelectAllHistory()">
                                <label class="form-check-label" for="dbSelectAllHistory">
                                    <strong>Select All</strong>
                                </label>
                            </div>
                            <button type="button" class="btn btn-danger btn-sm" onclick="dbBulkDeleteHistory()" id="dbBtnBulkDelete" disabled>
                                <i class="fas fa-trash"></i> Delete Selected (<span id="dbSelectedCount">0</span>)
                            </button>
                        </div>

                        <div class="text-center py-3" id="dbHistoryLoader" style="display: none;">
                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                            <p class="mt-2">Loading more records...</p>
                        </div>

                        <div class="text-center py-3" id="dbHistoryEndMessage" style="display: none;">
                            <p class="text-muted"><i class="fas fa-check-circle"></i> All records loaded</p>
                        </div>
                    </div>

                    <!-- Panel 3: Settings -->
                    <div class="tab-pane fade" id="dbSettingsPanel" role="tabpanel">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> Configure alarm settings for Tank Movement monitoring (ROT operations).
                            <br/><small class="text-muted">Only tanks with <strong>ROT OPEN</strong> tickets in the last 3 days are shown.</small>
                        </div>

                        <form id="dbAlarmSettingsForm">
                            <div class="form-group">
                                <label for="dbAlarmTankSelect"><strong>Select Tank (ROT OPEN):</strong></label>
                                <div class="input-group">
                                    <select class="form-control" id="dbAlarmTankSelect" name="tankName" required onchange="onDbAlarmTankSelected()">
                                        <option value="">-- Loading tanks... --</option>
                                    </select>
                                    <div class="input-group-append">
                                        <button type="button" class="btn btn-outline-secondary" onclick="loadDbTanksWithRecentROT()" title="Refresh tank list">
                                            <i class="fas fa-sync-alt"></i>
                                        </button>
                                    </div>
                                </div>
                                <small id="dbSelectedTicketInfo" class="form-text text-muted"></small>
                            </div>
                            <input type="hidden" id="dbSelectedAlarmTicketId" value="" />

                            <div id="dbSettingsFormGroup" style="display: none;">
                                <hr />
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label for="dbTargetLevel"><strong>Target Level (mm):</strong></label>
                                            <input type="number" class="form-control" id="dbTargetLevel" name="targetLevel" placeholder="e.g., 5000" />
                                            <small class="form-text text-muted">Leave empty to use Safe Capacity.</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label for="dbStagnantThreshold"><strong>Stagnant Threshold (minutes):</strong></label>
                                            <input type="number" class="form-control" id="dbStagnantThreshold" name="stagnantThresholdMinutes" placeholder="Default: 5" min="1" max="60" />
                                            <small class="form-text text-muted">Alarm will trigger if no flowrate for this duration.</small>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="dbIsManuallyConfigured" name="isManuallyConfigured" checked />
                                    <label class="form-check-label" for="dbIsManuallyConfigured">
                                        <strong>Lock Manual Settings</strong> (prevent auto-polling from overwriting)
                                    </label>
                                </div>

                                <div class="alert alert-secondary mt-3">
                                    <small>
                                        <strong>Note:</strong> If you uncheck "Lock Manual Settings", the system will automatically update settings from new tickets (FDM Web compatibility mode).
                                    </small>
                                </div>

                                <div id="dbCurrentSettingsInfo" class="mt-3"></div>
                            </div>
                        </form>
                    </div>

                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeDashboardAlarmModal();"><i class="fas fa-times"></i> Close</button>
                <button type="button" class="btn btn-warning" id="btnSaveDbAlarmSettings" onclick="saveDbAlarmSettings()" style="display: none;">
                    <i class="fas fa-save"></i> Save Settings
                </button>
            </div>
        </div>
    </div>
</div>
