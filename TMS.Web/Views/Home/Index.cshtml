        }

        /* Icon colors - sesuaikan dengan jenis data */
        .tank-level-text .tank-value-icon {
            color: #1d4ed8; /* Blue untuk level - darker */
        }

        .tank-temp-text .tank-value-icon {
            color: #b91c1c; /* Red untuk temperature - darker */
