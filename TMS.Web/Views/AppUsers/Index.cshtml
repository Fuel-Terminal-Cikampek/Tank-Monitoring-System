@model TMS.Web.Areas.Identity.Data.AppUser //ini ngambil modelnnya di area identity
@using TMS.Web.Authorization

@{
    ViewData["Title"] = "User Configuration";
    Layout = "~/Views/Shared/_LayoutNew.cshtml";
}
@*User List*@
<head>
    @section Scripts{
        <script type="text/javascript" asp-append-version="true">
            // ? Check if current user can modify data (admin only)
            var canModifyData = @Json.Serialize(User.CanModifyData());

            var oTable;
            // ? SAFEGUARD: Use jQuery(document).ready(function($) {}) pattern
            jQuery(document).ready(function ($) {
                oTable = $('#tb-user').DataTable(
                    {
                        "serverSide": true, //for process server side
                        "scrollY": "500px",
                        "scrollX": true,
                        "autoWidth": false,
                        "scrollCollapse": true,
                        "paging": true,
                        "fixedColumns": true,
                        "ajax": {
                            "url": "@Url.Action("LoadData")",
                            "type": "POST",
                            "datatype": "json"
                        },
                        "columnDefs": [{
                            "targets": 0,
                            "visible": false,
                            "searchable": false
                        }],
                        "columns": [
                            { "data": "id", "name": "Id", "autoWidth": true },
                            {
                                data: null,
                                render: function (data, type, full, meta) {
                                    var edit = canModifyData ? "<button type='button' class='btn btn-warning'onclick=UpdateData('" + full.id + "');><i class='fas fa-edit fa-lg'></i> Edit</button> " : "";
                                    var dlete = canModifyData ? "<button type='button' class='btn btn-danger' onclick=DeleteData('" + full.id + "');><i class='fas fa-trash-alt'></i>Delete</button>" : "";
                                    return edit + dlete;
                                }
                            },

                            { "data": "userName", "name": "UserName", "autoWidth": true },
                            { "data": "role", "name": "Role", "autoWidth": true },
                            { "data": "email", "name": "Email", "autoWidth": true },
                            { "data": "phoneNumber", "name": "PhoneNumber", "autoWidth": true },
                        ]
                    });
            }); //end document ready
            //update data
            function UpdateData(Id) {
                var toSend =
                {
                    id: Id
                };
                $.ajax({
                    type: "GET",
                    contentType: "application/json; charset=utf-8",
                    url: '@Url.Action("AddOrEdit")',
                    data: toSend,
                    success: function (res) {
                        $("#form-modal .modal-body").html(res);
                        $("#form-modal .modal-title").html('Edit User');
                        $("#form-modal").modal('show');
                    },
                    error: function (res) {
                    }
                })
            }
            //end update data
            //start delete data
            function DeleteData(Id) {
                if (confirm('Are you sure want to delete this user?')) {
                    var toSend =
                    {
                        id: Id
                    };
                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("Delete")",
                        data: toSend,
                        success: function (res) {
                            oTable = $('#tb-user').DataTable();
                            oTable.ajax.reload(null, false);
                        },
                        error: function (err) {
                        }
                    })
                }
            }
        </script>
    }
</head>

<!-- Begin Page Content -->
<div class="container-fluid">

    <!-- Page Heading --->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">User List</h1>
        <a value="reload" onclick="reloadTable()" class="d-none d-sm-inline-block btn btn-sm btn-info shadow-sm">
            <i class="fas fa-redo-alt"></i>
        </a>
    </div>

    <!-- Submain Containt -->
    <div class="card shadow-lg rounded" style="width: 100%;">
        <div class="card-header bg-gradient-info"></div>
        <div class="card-body">

            <!-- User Filter -->
            <form>
                <div class="form-row">
                    <div class="col-md-2">
                        <div class="input-group mb-3">
                            <div class="input-group-prepend">
                                <span class="input-group-text" id="Name"><i class="fab fa-slack-hash"></i></span>
                            </div>
                            <input type="text" class="form-control" placeholder="Name" aria-label="Name" aria-describedby="Name" id="Name">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="input-group mb-2">
                            <div class="input-group-prepend">
                                <span class="input-group-text" id="Email"><i class="fab fa-slack-hash"></i></span>
                            </div>
                            <input type="text" class="form-control" placeholder="Email" aria-label="Email" aria-describedby="Email" id="Email">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="input-group mb-1">
                            <button type="reset" class="btn btn-primary" style="width: 100%;" onclick="reset()"><i class="fas fa-undo-alt"></i>Reset Filter</button>
                        </div>
                    </div>
                    @* ? Only admins can create *@
                    @if (User.CanModifyData())
                    {
                        <div class="col-md-3">
                            <div class="input-group mb-1">
                                <button type="button" class="btn btn-primary" style="width: 100%;" onclick="showInPopup('@Url.Action("AddOrEdit","AppUsers", null, Context.Request.Scheme)','Add New User')"><i class="fas fa-plus"></i>New</button>
                            </div>
                        </div>
                    }
                </div>
            </form>

            <!-- End User Filter -->
            <!-- Divider -->
            <hr class="sidebar-divider my-3">

            <!-- User Table -->
            @await Html.PartialAsync("_ViewAll", Model)

            <!-- End User Table -->
        </div>
    </div>
    <!-- End Submain Content -->
</div>
<!-- End Page Content -->