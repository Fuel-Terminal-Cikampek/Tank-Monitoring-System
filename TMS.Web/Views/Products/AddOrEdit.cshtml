@model TMS.Models.Product

@{
    ViewData["Title"] = "AddOrEdit";
    Layout = null;
}

<div class="row">
    <div class="col-md-12">
        <form asp-action="AddOrEdit" asp-route-id="@Model.Product_ID" onsubmit="return jQueryAjaxPost(this);" autocomplete="off">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Product_ID" />
            <div class="form-group">
                <label asp-for="Product_Code" class="control-label"></label>
                <input asp-for="Product_Code" class="form-control" />
                <span asp-validation-for="Product_Code" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Product_Name" class="control-label"></label>
                <input asp-for="Product_Name" class="form-control" />
                <span asp-validation-for="Product_Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="HexColor" class="control-label"></label>
                <input asp-for="HexColor" class="form-control" />
                <span asp-validation-for="HexColor" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Default_Density" class="control-label"></label>
                <input asp-for="Default_Density" class="form-control" />
                <span asp-validation-for="Default_Density" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Default_Temp" class="control-label"></label>
                <input asp-for="Default_Temp" class="form-control" />
                <span asp-validation-for="Default_Temp" class="text-danger"></span>
            </div>
            <div class="form-group col text-center mt-lg-5">
                <button type="submit" class="btn btn-success" style="width:50%">Save changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
