@model TMS.Models.TankTicket

@{
    ViewData["Title"] = "AddTankTicket";
    Layout = null;
}
<script>
    var date01;
    var date02;
    var time01;
    var time02;
    var tankID = '@Model.Tank_Id';

    // Custom filtering function which will search data in column four between two values

    $(document).ready(function () {
        // Create date inputs
        date01 = new DateTime($('#date01'), {
            format: 'D MMM YYYY'
        });

        date02 = new DateTime($('#date02'), {
            format: 'D MMM YYYY'
        });
        time01 = new DateTime($('#time01'), {
            format: 'HH:mm'
        });
        time02 = new DateTime($('#time02'), {
            format: 'HH:mm'
        });
        
        // ? TAMBAHAN: Auto-reload data ketika tanggal/waktu berubah
        $('#date01, #time01').on('change', function() {
            loadDataOpen();
        });
        
        $('#date02, #time02').on('change', function() {
            loadDataClose();
        });
        
        // Load initial data
        loadData();
    });
    //get data Tank by Id
    function loadData() {
        var id = document.getElementById("Tank_Id").value;
        var Method = 'Automatic';//document.getElementById("Measurement_Method").value;
        var time = '@DateTime.Now.ToString("d MMM yyyy HH:mm:ss")';
        if (id != 0) {
            GetData(id, Method, time);
        }
    }

    //get data open Tank by Id
    function loadDataOpen() {
        var id = document.getElementById("Tank_Id").value;
        var Method = "Automatic";
        
        // ? PERBAIKAN: Format waktu dengan benar untuk parsing di server
        var dateValue = document.getElementById("date01").value;
        var timeValue = document.getElementById("time01").value;
        
        // Gabungkan dan format ulang ke format yang bisa di-parse server
        // Format: "dd MMM yyyy HH:mm"
        var timerequest = dateValue + ' ' + timeValue + ':00';
        
        if (id != 0 && id != "" && dateValue && timeValue) {
            GetDataOpen(id, Method, timerequest);
        }
    }

    //get data close Tank by Id
    function loadDataClose() {
        var id = document.getElementById("Tank_Id").value;
        var Method = "Automatic";
        var timerequest = document.getElementById("date02").value + ' ' +document.getElementById("time02").value;
        if (id != 0) {
            GetDataClose(id, Method, timerequest);
        }
    }

    // Collect data from forms and send to controller
    function SaveChanges() {
        var form1 = $('#form1').serializeArray();
        var form2 = $('#form2').serializeArray();
        var form3 = $('#form3').serializeArray();
        // Check if tankId is not filled
        if ($('#Tank_Id').val() == "0") {
            alert("Harap Inputkan Nomor Tanki");
            return; // Stop further execution
        }

        // Check if tankId is not filled
        if ($('#Operation_Type').val() == "--All Operation Type--") {
            alert("Harap Inputkan Tipe Operasi");
            return; // Stop further execution
        }

        // Convert each form data to object
        var formData1 = {};
        form1.forEach(function (item) {
            formData1[item.name] = item.value;
        });

        var formData2 = {};
        form2.forEach(function (item) {
            formData2[item.name] = item.value;
        });

        var formData3 = {};
        form3.forEach(function (item) {
            formData3[item.name] = item.value;
        });

        // Add checkbox value to formData2
        var checkStatusOpen = $('#CheckStatusOpen');
        formData2[checkStatusOpen.attr('id')] = checkStatusOpen.is(':checked') ? '1' : '2';

        // Add checkbox value to formData3
        var checkStatusClose = $('#CheckStatusClose');
        formData3[checkStatusClose.attr('id')] = checkStatusClose.is(':checked') ? '1' : '2';

        // Combine all form data into a single object
        var formsData = {
            form1: formData1,
            OpenFormData: formData2,
            CloseFormData: formData3
        };


        $.ajax({
            url: '@Url.Action("AddOpenCloseTankTicket", "TankTicket")',
            type: 'POST',
            data: JSON.stringify(formsData),
            contentType: 'application/json; charset=utf-8',
            success: function (response) {
                // Handle success
                $("#form-modal").modal('hide');
                oTable.ajax.reload(null, false);
            },
            error: function (xhr, status, error) {
                // Handle error
            }
        });
    }

    function SaveAndPost() {
        var form1 = $('#form1').serializeArray();
        var form2 = $('#form2').serializeArray();
        var form3 = $('#form3').serializeArray();

        // Check if tankId is not filled
        if ($('#Tank_Id').val() == "0") {
            alert("Harap Inputkan Nomor Tanki");
            return; // Stop further execution
        }

        // Check if tankId is not filled
        if ($('#Operation_Type').val() == "--All Operation Type--") {
            alert("Harap Inputkan Tipe Operasi");
            return; // Stop further execution
        }

        // Convert each form data to object
        var formData1 = {};
        form1.forEach(function (item) {
            formData1[item.name] = item.value;
        });

        // Tambahkan IsPosting ke formData1
        formData1['IsPosting'] = '1';

        console.log("Form Data 1")


        var formData2 = {};
        form2.forEach(function (item) {
            formData2[item.name] = item.value;
        });

        var formData3 = {};
        form3.forEach(function (item) {
            formData3[item.name] = item.value;
        });


        // Add checkbox value to formData2
        var checkStatusOpen = $('#CheckStatusOpen');
        formData2[checkStatusOpen.attr('id')] = checkStatusOpen.is(':checked') ? '1' : '2';

        // Add checkbox value to formData3
        var checkStatusClose = $('#CheckStatusClose');
        formData3[checkStatusClose.attr('id')] = checkStatusClose.is(':checked') ? '1' : '2';

        // Combine all form data into a single object
        var formsData = {
            form1: formData1,
            OpenFormData: formData2,
            CloseFormData: formData3
        };


        $.ajax({
            url: '@Url.Action("AddOpenCloseTankTicket", "TankTicket")',
            type: 'POST',
            data: JSON.stringify(formsData),
            contentType: 'application/json; charset=utf-8',
            success: function (response) {
                // Handle success
                if (response.isValid == true) {
                    $("#form-modal").modal('hide');
                    oTable.ajax.reload(null, false);
                }
                else {
                    alert(response.message)
                }
            },
            error: function (xhr, status, error) {
                // Handle error
            }
        });
    }

</script>


<style>
    .form-container {
        display: grid;
        grid-template-columns: 1fr 1fr; /* Dua kolom dengan ukuran yang sama */
        gap: 10px; /* Jarak antara kolom */
    }

    .bordered-form {
        border: 1px solid #ccc; /* Tambahkan border dengan warna abu-abu */
        padding: 20px; /* Berikan sedikit padding untuk memberikan ruang antara konten dan border */
        border-radius: 5px; /* Agar tampilan border terlihat lebih lembut */
    }

    .large-checkbox .form-check-input {
        width: 1.5em;
        height: 1.5em;
    }
</style>


