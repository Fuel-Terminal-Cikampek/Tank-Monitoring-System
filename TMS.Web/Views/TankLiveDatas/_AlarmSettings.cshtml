@model TMS.Web.Models.AlarmSettingsViewModel

@{
    // ✅ Store original content identifier for back navigation
    var tankName = ViewBag.TankName as string ?? "";
}

<form id="formAlarmSettings">
    @if (!Model.CanEdit)
    {
        <div class="alert alert-warning mb-3">
            <i class="fas fa-lock"></i> <strong>View Only:</strong> 
            Hanya akun Admin yang dapat mengubah pengaturan ini.
        </div>
    }

    <!-- Stagnant Detection -->
    <div class="card mb-3">
        <div class="card-header bg-info text-white py-2">
            <i class="fas fa-clock"></i> Stagnant Detection (No Flowrate)
        </div>
        <div class="card-body">
            <div class="form-group row mb-2">
                <label class="col-sm-6 col-form-label">Flowrate Tolerance (KL/h)</label>
                <div class="col-sm-6">
                    <input type="number" step="0.01" class="form-control" id="stagnantFlowrateTolerance" 
                           value="@Model.StagnantFlowrateToleranceKLH" @(Model.CanEdit ? "" : "readonly")>
                </div>
            </div>
            <div class="form-group row mb-0">
                <label class="col-sm-6 col-form-label">Default Threshold (Minutes)</label>
                <div class="col-sm-6">
                    <input type="number" class="form-control" id="defaultStagnantMinutes" 
                           value="@Model.DefaultStagnantThresholdMinutes" @(Model.CanEdit ? "" : "readonly")>
                </div>
            </div>
        </div>
    </div>

    <!-- Standby Anomaly -->
    <div class="card mb-3">
        <div class="card-header bg-secondary text-white py-2">
            <i class="fas fa-pause-circle"></i> Standby/Idle Anomaly
        </div>
        <div class="card-body">
            <div class="form-group row mb-2">
                <label class="col-sm-6 col-form-label">Flowrate Tolerance (KL/h)</label>
                <div class="col-sm-6">
                    <input type="number" step="0.1" class="form-control" id="standbyFlowrateTolerance" 
                           value="@Model.StandbyFlowrateToleranceKLH" @(Model.CanEdit ? "" : "readonly")>
                </div>
            </div>
            <div class="form-group row mb-0">
                <label class="col-sm-6 col-form-label">Level Change Tolerance (mm)</label>
                <div class="col-sm-6">
                    <input type="number" class="form-control" id="standbyLevelTolerance" 
                           value="@Model.StandbyLevelChangeToleranceMM" @(Model.CanEdit ? "" : "readonly")>
                </div>
            </div>
        </div>
    </div>

    <!-- Sales Anomaly -->
    <div class="card mb-3">
        <div class="card-header bg-danger text-white py-2">
            <i class="fas fa-arrow-down"></i> Sales Anomaly
        </div>
        <div class="card-body">
            <div class="form-group row mb-2">
                <label class="col-sm-6 col-form-label">Flowrate Tolerance (KL/h)</label>
                <div class="col-sm-6">
                    <input type="number" step="0.1" class="form-control" id="salesFlowrateTolerance" 
                           value="@Model.SalesFlowrateToleranceKLH" @(Model.CanEdit ? "" : "readonly")>
                </div>
            </div>
            <div class="form-group row mb-0">
                <label class="col-sm-6 col-form-label">Level Increase Tolerance (mm)</label>
                <div class="col-sm-6">
                    <input type="number" class="form-control" id="salesLevelTolerance" 
                           value="@Model.SalesLevelChangeToleranceMM" @(Model.CanEdit ? "" : "readonly")>
                </div>
            </div>
        </div>
    </div>

    <!-- Level Fluctuation -->
    <div class="card mb-3">
        <div class="card-header bg-primary text-white py-2">
            <i class="fas fa-wave-square"></i> Level Fluctuation
        </div>
        <div class="card-body">
            <div class="form-group row mb-0">
                <label class="col-sm-6 col-form-label">Fluctuation Tolerance (mm)</label>
                <div class="col-sm-6">
                    <input type="number" class="form-control" id="levelFluctuationTolerance" 
                           value="@Model.LevelFluctuationToleranceMM" @(Model.CanEdit ? "" : "readonly")>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- ✅ FIX: Footer dengan tombol Back (kembali ke Operational Status) -->
<div class="mt-3 text-right">
    <button type="button" class="btn btn-secondary" onclick="backToOperationalStatus()">
        <i class="fas fa-arrow-left"></i> Back
    </button>
    @if (Model.CanEdit)
    {
        <button type="button" class="btn btn-success" onclick="saveAlarmSettings()">
            <i class="fas fa-save"></i> Save Settings
        </button>
    }
</div>

<script>
    // ✅ FIX: Back to Operational Status (tidak menutup modal)
    function backToOperationalStatus() {
        var $ = jQuery;
        var tankName = '@tankName';
        
        // Jika ada tankName, load kembali Operational Status
        if (tankName && tankName !== '') {
            $.ajax({
                url: '/TankLiveDatas/GetOperationalStatus',
                type: 'GET',
                data: { tankName: tankName },
                success: function(res) {
                    $('#form-modal .modal-body').html(res);
                    $('#form-modal .modal-title').text('Update Operational Status');
                },
                error: function(xhr, status, error) {
                    // Fallback: tutup modal jika gagal
                    $('#form-modal').modal('hide');
                }
            });
        } else {
            // Jika tidak ada tankName, tutup modal
            $('#form-modal').modal('hide');
        }
    }
    
    function saveAlarmSettings() {
        var $ = jQuery;
        
        var data = {
            StagnantFlowrateToleranceKLH: parseFloat($('#stagnantFlowrateTolerance').val()) || 0.05,
            DefaultStagnantThresholdMinutes: parseInt($('#defaultStagnantMinutes').val()) || 5,
            StandbyFlowrateToleranceKLH: parseFloat($('#standbyFlowrateTolerance').val()) || 20.0,
            StandbyLevelChangeToleranceMM: parseInt($('#standbyLevelTolerance').val()) || 10,
            SalesFlowrateToleranceKLH: parseFloat($('#salesFlowrateTolerance').val()) || 20.0,
            SalesLevelChangeToleranceMM: parseInt($('#salesLevelTolerance').val()) || 5,
            LevelFluctuationToleranceMM: parseInt($('#levelFluctuationTolerance').val()) || 2
        };

        $.ajax({
            type: "POST",
            url: "/TankLiveDatas/SaveAlarmSettings",
            contentType: "application/json",
            data: JSON.stringify(data),
            success: function(res) {
                if (res.success) {
                    alert('✅ ' + res.message);
                    // ✅ Kembali ke Operational Status setelah save
                    backToOperationalStatus();
                } else {
                    alert('❌ ' + res.message);
                }
            },
            error: function(err) {
                alert('Error: ' + err.statusText);
            }
        });
    }
</script>